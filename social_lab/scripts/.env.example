# social_lab/scripts/.env (gitignored)
#
# Credenziali Telegram per le notifiche del bridge.
# Sono gli stessi valori che hai configurato come Firebase secrets per il
# manager (TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID). Qui li tieni in chiaro
# perché lo script gira localmente sulla tua macchina, non su cloud.
#
# Setup: copia questo file come `.env` e popola i due valori.
#   cp .env.example .env
#
# Senza questo file il bridge funziona uguale, ma non ti manda la notifica
# Telegram a fine push. Riceverai comunque l'output sul terminale.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
