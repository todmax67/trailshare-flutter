rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── BUSINESS / SPAZIO PRO ────────────────────────────────────────
    // Read pubblico (foto profilo, hero, gallery, post, services).
    // Write da utente autenticato. Owner check vero richiederebbe Firestore
    // get cross-service che nel nostro progetto dà 403 (vedi memoria
    // feedback_storage_rules); ci affidiamo a UI gating + audit.
    // Limiti: max 5MB, solo immagini.
    match /businesses/{businessId}/{kind}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // ─── TRACCE (foto su tracce esistenti) ────────────────────────────
    // Pattern esistente preservato. Adatta se le tue rules prod sono diverse.
    match /tracks/{userId}/{trackId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ─── User avatars (se usati) ──────────────────────────────────────
    match /users/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny per path non riconosciuti
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
